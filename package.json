{
  "name": "lithium",
  "version": "0.2.0",
  "description": "Lithium — UI for Claude Code",
  "author": "Laurens Kosters",
  "main": "main.js",
  "productName": "Lithium",
  "scripts": {
    "start": "npx electron .",
    "rebuild": "npx @electron/rebuild",
    "postinstall": "node scripts/patch-electron-name.js",
    "build": "npx electron-builder --mac",
    "build:win": "npx electron-builder --win",
    "build:linux": "npx electron-builder --linux",
    "build:all": "npx electron-builder --mac --win --linux"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "node-pty": "^1.0.0",
    "uuid": "^11.0.0"
  },
  "optionalDependencies": {
    "@anthropic-ai/sdk": "^0.39.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "electron": "33.4.11",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.lithium.app",
    "productName": "Lithium",
    "mac": {
      "target": "dmg",
      "icon": "public/icon.png",
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.png"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.png",
      "category": "Development"
    },
    "files": [
      "main.js",
      "src/**/*",
      "public/**/*",
      "music/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [],
    "asar": true
  }
}
